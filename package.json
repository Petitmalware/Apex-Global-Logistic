{
  "name": "apex-global-logistics",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready Next.js 15 foundation for Apex Global Logistics.",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "prisma generate && next build && node scripts/copy-standalone-assets.mjs",
    "check": "npm run lint && npm run typecheck && npm run format",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "node scripts/prisma-with-env.mjs migrate deploy",
    "db:migrate": "node scripts/prisma-with-env.mjs migrate dev",
    "db:push": "node scripts/prisma-with-env.mjs db push",
    "db:seed": "node scripts/prisma-with-env.mjs db seed",
    "db:studio": "node scripts/prisma-with-env.mjs studio",
    "db:validate": "node scripts/prisma-validate.mjs",
    "dev": "next dev --turbo",
    "docker:down": "docker compose down",
    "docker:prod:down": "docker compose --env-file .env.production -f deploy/docker-compose.prod.yml down",
    "docker:prod:up": "docker compose --env-file .env.production -f deploy/docker-compose.prod.yml up -d --build",
    "docker:up": "docker compose up -d",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "lint-staged": "lint-staged",
    "lint:fix": "eslint . --fix",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "start": "next start",
    "vps:deploy": "bash deploy/scripts/deploy-docker.sh",
    "typecheck": "tsc --noEmit",
    "ui:add": "npx shadcn@latest add"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-slot": "^1.2.3",
    "@react-email/components": "^1.0.12",
    "@types/sanitize-html": "^2.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.475.0",
    "next": "^15.5.0",
    "nodemailer": "^9.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "sanitize-html": "^2.17.5",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/google.maps": "^3.65.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}

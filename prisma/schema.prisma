  SMTP
}

enum ActivityAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  SYSTEM
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_INTERNAL
  RESOLVED
  CLOSED
}

enum TicketMessageAuthorType {
  USER
  STAFF
  SYSTEM
}

enum ChatConversationStatus {
  OPEN
  PENDING_CUSTOMER
  PENDING_STAFF
  RESOLVED
  CLOSED
}

enum ChatMessageAuthorType {
  VISITOR
  CUSTOMER
  STAFF
  AI
  SYSTEM
}

enum AiConversationStatus {
  OPEN
  ARCHIVED
  DELETED
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum SettingScope {
  GLOBAL
  ORGANIZATION
  WAREHOUSE
  USER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  ASSIGN
  APPROVE
  REJECT
  SYSTEM
}

model Organization {
  id            String             @id @default(uuid()) @db.Uuid
  name          String             @db.VarChar(160)
  slug          String             @unique @db.VarChar(120)
  status        OrganizationStatus @default(ACTIVE)
  legalName     String?            @db.VarChar(200)
  taxIdentifier String?            @db.VarChar(80)
  email         String?            @db.VarChar(255)
  phone         String?            @db.VarChar(40)
  website       String?            @db.VarChar(255)
  metadata      Json?
  createdAt     DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime?          @db.Timestamptz(6)

  addresses         Address[]
  activityLogs      ActivityLog[]
  aiConversations   AiConversation[]
  auditLogs         AuditLog[]
  chatConversations ChatConversation[]
  emailLogs         EmailLog[]
  drivers           Driver[]
  emailTemplates    EmailTemplate[]
  invoices          Invoice[]
  notifications     Notification[]
  roles             Role[]
  settings          Setting[]
  shipments         Shipment[]
  supportTickets    SupportTicket[]
  userRoles         UserRole[]
  users             User[]
  vehicles          Vehicle[]
  warehouses        Warehouse[]

  @@index([status, createdAt], map: "idx_organizations_status_created_at")
  @@index([deletedAt], map: "idx_organizations_deleted_at")
}

model Address {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String?     @db.Uuid
  type           AddressType @default(OTHER)
  name           String?     @db.VarChar(120)
  line1          String      @db.VarChar(255)
  line2          String?     @db.VarChar(255)
  city           String      @db.VarChar(120)
  state          String?     @db.VarChar(120)
  postalCode     String?     @db.VarChar(32)
  countryCode    String      @db.Char(2)
  latitude       Decimal?    @db.Decimal(9, 6)
  longitude      Decimal?    @db.Decimal(9, 6)
  createdAt      DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @db.Timestamptz(6)

  organization         Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingInvoices      Invoice[]       @relation("InvoiceBillingAddress")
  destinationShipments Shipment[]      @relation("ShipmentDestinationAddress")
  originShipments      Shipment[]      @relation("ShipmentOriginAddress")
  trackingEvents       TrackingEvent[] @relation("TrackingEventAddress")
  warehouses           Warehouse[]     @relation("WarehouseAddress")

  @@index([organizationId, type], map: "idx_addresses_organization_type")
  @@index([countryCode, city], map: "idx_addresses_country_city")
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  organizationId    String?    @db.Uuid
  email             String     @unique @db.VarChar(255)
  name              String     @db.VarChar(160)
  phone             String?    @db.VarChar(40)
  hashedPassword    String?    @db.VarChar(255)
  status            UserStatus @default(INVITED)
  emailVerifiedAt   DateTime?  @db.Timestamptz(6)
  passwordChangedAt DateTime?  @db.Timestamptz(6)
  lastLoginAt       DateTime?  @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?  @db.Timestamptz(6)

  organization              Organization?             @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  activityLogs              ActivityLog[]             @relation("ActivityLogActor")
  aiConversations           AiConversation[]
  assignedRoleGrants        UserRole[]                @relation("AssignedUserRoles")
  assignedVehicleGrants     DriverVehicleAssignment[] @relation("DriverVehicleAssignedBy")
  assignedSupportTickets    SupportTicket[]           @relation("SupportTicketAssignee")
  assignedChatConversations ChatConversation[]        @relation("ChatConversationAssignee")
  auditLogs                 AuditLog[]                @relation("AuditLogActor")
  authoredChatMessages      ChatMessage[]             @relation("ChatMessageAuthor")
  customerChatConversations ChatConversation[]        @relation("ChatConversationCustomer")
  createdEmailTemplates     EmailTemplate[]           @relation("EmailTemplateCreatedBy")
  receivedEmailLogs         EmailLog[]                @relation("EmailLogRelatedUser")
  createdShipments          Shipment[]                @relation("ShipmentCreatedBy")
  customerInvoices          Invoice[]                 @relation("InvoiceCustomer")
  customerShipments         Shipment[]                @relation("ShipmentCustomer")
  driverProfile             Driver?                   @relation("DriverUser")
  notifications             Notification[]
  passwordResetTokens       PasswordResetToken[]
  recordedTrackingEvents    TrackingEvent[]           @relation("TrackingRecordedBy")
  requestedSupportTickets   SupportTicket[]           @relation("SupportTicketRequester")
  refreshTokens             RefreshToken[]
  settings                  Setting[]                 @relation("SettingOwner")
  sentEmailLogs             EmailLog[]                @relation("EmailLogSentBy")
  supportTicketMessages     SupportTicketMessage[]    @relation("SupportTicketMessageAuthor")
  emailVerificationTokens   EmailVerificationToken[]
  uploadedShipmentDocuments ShipmentDocument[]        @relation("ShipmentDocumentUploadedBy")
  uploadedPackagePhotos     ShipmentPackagePhoto[]    @relation("ShipmentPackagePhotoUploadedBy")
  uploadedPetPhotos         PetTransportPhoto[]       @relation("PetTransportPhotoUploadedBy")
  uploadedPetVaccinations   PetVaccinationRecord[]    @relation("PetVaccinationRecordUploadedBy")
  uploadedPetCertificates   PetMedicalCertificate[]   @relation("PetMedicalCertificateUploadedBy")
  recordedPetVetChecks      PetVeterinarianCheck[]    @relation("PetVeterinarianCheckRecordedBy")
  createdPetFeedings        PetFeedingSchedule[]      @relation("PetFeedingScheduleCreatedBy")
  recordedPetTemperatures   PetTemperatureLog[]       @relation("PetTemperatureLogRecordedBy")
  assignedPetCrates         PetCrateAssignment[]      @relation("PetCrateAssignmentAssignedBy")
  recordedPetTravelHistory  PetTravelHistory[]        @relation("PetTravelHistoryRecordedBy")
  uploadedFreightDocuments  FreightDocument[]         @relation("FreightDocumentUploadedBy")
  recordedFreightEvents     FreightTrackingEvent[]    @relation("FreightTrackingEventRecordedBy")
  updatedEmailTemplates     EmailTemplate[]           @relation("EmailTemplateUpdatedBy")
  updatedSettings           Setting[]                 @relation("SettingUpdatedBy")
  userRoles                 UserRole[]                @relation("UserRoleUser")

  @@index([organizationId, status], map: "idx_users_organization_status")
  @@index([emailVerifiedAt], map: "idx_users_email_verified_at")
  @@index([deletedAt], map: "idx_users_deleted_at")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  tokenHash         String    @unique @db.Char(64)
  familyId          String    @db.Uuid
  expiresAt         DateTime  @db.Timestamptz(6)
  revokedAt         DateTime? @db.Timestamptz(6)
  replacedByTokenId String?   @db.Uuid
  createdByIp       String?   @db.VarChar(45)
  revokedByIp       String?   @db.VarChar(45)
  userAgent         String?   @db.Text
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  replacedBy RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replaces   RefreshToken[] @relation("RefreshTokenRotation")
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "idx_refresh_tokens_user_expires_at")
  @@index([familyId, revokedAt], map: "idx_refresh_tokens_family_revoked_at")
  @@index([revokedAt, expiresAt], map: "idx_refresh_tokens_revoked_expires_at")
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique @db.Char(64)
  expiresAt   DateTime  @db.Timestamptz(6)
  usedAt      DateTime? @db.Timestamptz(6)
  createdByIp String?   @db.VarChar(45)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "idx_password_reset_tokens_user_expires_at")
  @@index([usedAt, expiresAt], map: "idx_password_reset_tokens_used_expires_at")
}

model EmailVerificationToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique @db.Char(64)
  expiresAt   DateTime  @db.Timestamptz(6)
  usedAt      DateTime? @db.Timestamptz(6)
  createdByIp String?   @db.VarChar(45)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "idx_email_verification_tokens_user_expires_at")
  @@index([usedAt, expiresAt], map: "idx_email_verification_tokens_used_expires_at")
}

model Role {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @db.Uuid
  name           String    @db.VarChar(120)
  key            String    @db.VarChar(120)
  scope          RoleScope @default(ORGANIZATION)
  description    String?   @db.Text
  isSystem       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([organizationId, key], map: "uq_roles_organization_key")
  @@index([scope], map: "idx_roles_scope")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(160)
  resource    String           @db.VarChar(120)
  action      PermissionAction
  description String?          @db.Text
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([resource, action], map: "idx_permissions_resource_action")
}

model RolePermission {
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "idx_role_permissions_permission_id")
}

model UserRole {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  roleId         String    @db.Uuid
  organizationId String?   @db.Uuid
  warehouseId    String?   @db.Uuid
  assignedById   String?   @db.Uuid
  expiresAt      DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  assignedBy   User?         @relation("AssignedUserRoles", fields: [assignedById], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user         User          @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, organizationId, warehouseId], map: "uq_user_roles_scope")
  @@index([roleId], map: "idx_user_roles_role_id")
  @@index([organizationId, warehouseId], map: "idx_user_roles_scope_lookup")
  @@index([expiresAt], map: "idx_user_roles_expires_at")
}

model Warehouse {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  addressId      String          @db.Uuid
  code           String          @db.VarChar(40)
  name           String          @db.VarChar(160)
  status         WarehouseStatus @default(ACTIVE)
  timezone       String          @default("UTC") @db.VarChar(80)
  phone          String?         @db.VarChar(40)
  email          String?         @db.VarChar(255)
  metadata       Json?
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt      DateTime?       @db.Timestamptz(6)

  address              Address         @relation("WarehouseAddress", fields: [addressId], references: [id], onDelete: Restrict)
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  destinationShipments Shipment[]      @relation("ShipmentDestinationWarehouse")
  drivers              Driver[]        @relation("DriverHomeWarehouse")
  originShipments      Shipment[]      @relation("ShipmentOriginWarehouse")
  settings             Setting[]
  trackingEvents       TrackingEvent[]
  userRoles            UserRole[]
  vehicles             Vehicle[]       @relation("VehicleCurrentWarehouse")

  @@unique([organizationId, code], map: "uq_warehouses_organization_code")
  @@index([organizationId, status], map: "idx_warehouses_organization_status")
  @@index([deletedAt], map: "idx_warehouses_deleted_at")
}

model Driver {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  userId           String?      @unique @db.Uuid
  homeWarehouseId  String?      @db.Uuid
  employeeNumber   String       @db.VarChar(80)
  licenseNumber    String       @unique @db.VarChar(120)
  licenseExpiresAt DateTime?    @db.Date
  status           DriverStatus @default(AVAILABLE)
  metadata         Json?
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime?    @db.Timestamptz(6)

  homeWarehouse      Warehouse?                @relation("DriverHomeWarehouse", fields: [homeWarehouseId], references: [id], onDelete: SetNull)
  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user               User?                     @relation("DriverUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedShipments  Shipment[]                @relation("ShipmentAssignedDriver")
  trackingEvents     TrackingEvent[]
  vehicleAssignments DriverVehicleAssignment[]

  @@unique([organizationId, employeeNumber], map: "uq_drivers_organization_employee_number")
  @@index([organizationId, status], map: "idx_drivers_organization_status")
  @@index([homeWarehouseId, status], map: "idx_drivers_home_warehouse_status")
  @@index([deletedAt], map: "idx_drivers_deleted_at")
}

model Vehicle {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String        @db.Uuid
  currentWarehouseId String?       @db.Uuid
  registrationNumber String        @unique @db.VarChar(80)
  vin                String?       @unique @db.VarChar(80)
  type               VehicleType
  status             VehicleStatus @default(AVAILABLE)
  capacityKg         Decimal?      @db.Decimal(12, 3)
  capacityVolumeCbm  Decimal?      @db.Decimal(12, 3)
  mileageKm          Int?
  metadata           Json?
  createdAt          DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @db.Timestamptz(6)
  deletedAt          DateTime?     @db.Timestamptz(6)

  currentWarehouse   Warehouse?                @relation("VehicleCurrentWarehouse", fields: [currentWarehouseId], references: [id], onDelete: SetNull)
  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  shipments          Shipment[]                @relation("ShipmentVehicle")
  trackingEvents     TrackingEvent[]
  vehicleAssignments DriverVehicleAssignment[]

  @@index([organizationId, status], map: "idx_vehicles_organization_status")
  @@index([currentWarehouseId, status], map: "idx_vehicles_current_warehouse_status")
  @@index([deletedAt], map: "idx_vehicles_deleted_at")
}

model DriverVehicleAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  driverId     String    @db.Uuid
  vehicleId    String    @db.Uuid
  assignedById String?   @db.Uuid
  assignedAt   DateTime  @default(now()) @db.Timestamptz(6)
  releasedAt   DateTime? @db.Timestamptz(6)
  notes        String?   @db.Text

  assignedBy User?   @relation("DriverVehicleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  driver     Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle    Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([driverId, releasedAt], map: "idx_driver_vehicle_assignments_driver_active")
  @@index([vehicleId, releasedAt], map: "idx_driver_vehicle_assignments_vehicle_active")
}

model Shipment {
  id                     String           @id @default(uuid()) @db.Uuid
  organizationId         String           @db.Uuid
  shipmentNumber         String           @db.VarChar(80)
  customerId             String?          @db.Uuid
  createdById            String?          @db.Uuid
  assignedDriverId       String?          @db.Uuid
  vehicleId              String?          @db.Uuid
  originAddressId        String           @db.Uuid
  destinationAddressId   String           @db.Uuid
  originWarehouseId      String?          @db.Uuid
  destinationWarehouseId String?          @db.Uuid
  status                 ShipmentStatus   @default(DRAFT)
  priority               ShipmentPriority @default(STANDARD)
  mode                   ShipmentMode     @default(ROAD)
  serviceLevel           String?          @db.VarChar(80)
  referenceNumber        String?          @db.VarChar(120)
  pickupWindowStart      DateTime?        @db.Timestamptz(6)
  pickupWindowEnd        DateTime?        @db.Timestamptz(6)
  deliveryWindowStart    DateTime?        @db.Timestamptz(6)
  deliveryWindowEnd      DateTime?        @db.Timestamptz(6)
  bookedAt               DateTime?        @db.Timestamptz(6)
  dispatchedAt           DateTime?        @db.Timestamptz(6)
  deliveredAt            DateTime?        @db.Timestamptz(6)
  cancelledAt            DateTime?        @db.Timestamptz(6)
  cancellationReason     String?          @db.Text
  notes                  String?          @db.Text
  metadata               Json?

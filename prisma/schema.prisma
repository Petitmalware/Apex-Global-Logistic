  value          Json
  valueType      String       @default("json") @db.VarChar(40)
  isEncrypted    Boolean      @default(false)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy    User?         @relation("SettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  user         User?         @relation("SettingOwner", fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([scope, organizationId, warehouseId, userId, key], map: "uq_settings_scope_owner_key")
  @@index([key], map: "idx_settings_key")
  @@index([organizationId, scope], map: "idx_settings_organization_scope")
}

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String?     @db.Uuid
  actorId        String?     @db.Uuid
  action         AuditAction
  entityType     String      @db.VarChar(120)
  entityId       String?     @db.VarChar(120)
  before         Json?
  after          Json?
  ipAddress      String?     @db.VarChar(45)
  userAgent      String?     @db.Text
  correlationId  String?     @db.VarChar(120)
  occurredAt     DateTime    @default(now()) @db.Timestamptz(6)

  actor        User?         @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt], map: "idx_audit_logs_organization_occurred_at")
  @@index([actorId, occurredAt], map: "idx_audit_logs_actor_occurred_at")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([correlationId], map: "idx_audit_logs_correlation_id")
}

enum EmailTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EmailTemplateCategory {
  ADMIN
  AUTH
  BILLING
  FREIGHT
  INVOICE
  MANUAL
  PACKAGE
  PAYMENT
  PET
  SHIPMENT
  SYSTEM
}

enum EmailLogStatus {
  DRAFT

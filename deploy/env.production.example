APP_ENV=production
NODE_ENV=production
APP_PORT=3000
NEXT_PUBLIC_APP_URL=https://apex.example.com

POSTGRES_DB=apex_global_logistics
POSTGRES_USER=apex
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
DATABASE_URL=postgresql://apex:replace-with-a-long-random-postgres-password@postgres:5432/apex_global_logistics?schema=public

REDIS_URL=redis://redis:6379

AUTH_JWT_SECRET=replace-with-at-least-32-random-characters-for-production
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_PASSWORD_RESET_TTL_MINUTES=30
AUTH_EMAIL_VERIFICATION_TTL_HOURS=24

SECURITY_LOGIN_RATE_LIMIT_PER_MINUTE=10
SECURITY_AUTH_RATE_LIMIT_PER_MINUTE=20
SECURITY_EMAIL_SEND_RATE_LIMIT_PER_MINUTE=10
SECURITY_AI_RATE_LIMIT_PER_MINUTE=30
SECURITY_PUBLIC_TRACKING_RATE_LIMIT_PER_MINUTE=60
SECURITY_API_RATE_LIMIT_PER_MINUTE=120
SECURITY_ACTION_RATE_LIMIT_PER_MINUTE=60

STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=storage
MINIO_ROOT_USER=apex_minio
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=apex-uploads
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=apex_minio
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-minio-password
S3_PUBLIC_URL=

AI_PROVIDER=local
AI_REQUEST_TIMEOUT_MS=30000
AI_SEMANTIC_SEARCH_LIMIT=8
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

EMAIL_PROVIDER=console
EMAIL_FROM=notifications@apex.example.com
EMAIL_RATE_LIMIT_PER_HOUR=60
RESEND_API_KEY=
BREVO_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SUPPORT_EMAIL=support@apex.example.com
SUPPORT_PHONE=+1 (800) 555-0199
NOTIFICATION_EMAIL_PROVIDER=console
NOTIFICATION_EMAIL_FROM=notifications@apex.example.com

BACKUP_RETENTION_DAYS=14
BACKUP_DIR=backups

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-grafana-password
GRAFANA_ROOT_URL=https://grafana.apex.example.com
